<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pos.posnghalagako.controller.DashboardController">

    <!-- Header -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10;">
            <Label fx:id="welcomeLabel" text="Welcome!" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label fx:id="roleLabel" text=""/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- Center -->
    <center>
        <VBox alignment="CENTER" spacing="20">
            <Label text="POSngHALAGAko" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Select an option:"/>

            <HBox alignment="CENTER" spacing="20">
                <Button text="POS (Point of Sale)" onMouseClicked="#handleOpenPOS"
                        prefWidth="180" prefHeight="60" style="-fx-font-size: 14px;"/>
                <Button text="Product Management" onMouseClicked="#handleOpenProducts"
                        prefWidth="180" prefHeight="60" style="-fx-font-size: 14px;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
