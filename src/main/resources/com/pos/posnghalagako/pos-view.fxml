<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pos.posnghalagako.controller.POSController">

    <!-- Header -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 8;">
            <Button text="Back" onAction="#handleBack"/>
            <Label text="Point of Sale" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="cashierLabel" text=""/>
        </HBox>
    </top>

    <!-- Left — Product List -->
    <center>
        <VBox spacing="8" style="-fx-padding: 10;">
            <Label text="Products:" style="-fx-font-weight: bold;"/>
            <ListView fx:id="productListView" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

    <!-- Right — Cart -->
    <right>
        <VBox spacing="10" style="-fx-padding: 10;" prefWidth="350">
            <Label text="Cart:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colCartProduct" text="Product" prefWidth="120"/>
                    <TableColumn fx:id="colCartQty" text="Qty" prefWidth="50"/>
                    <TableColumn fx:id="colCartPrice" text="Price" prefWidth="70"/>
                    <TableColumn fx:id="colCartSubtotal" text="Subtotal" prefWidth="80"/>
                </columns>
                <placeholder>
                    <Label text="Cart is empty"/>
                </placeholder>
            </TableView>

            <Button text="Remove Selected" onAction="#handleRemoveItem" maxWidth="Infinity"/>

            <Separator/>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Label text="TOTAL:" style="-fx-font-weight: bold;"/>
                <Label fx:id="totalLabel" text="0.00" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>

            <Separator/>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Amount Paid:"/>
                <TextField fx:id="amountPaidField" promptText="Enter amount" prefWidth="120"/>
            </HBox>
            <Label fx:id="changeLabel" text=""/>

            <HBox spacing="10">
                <Button text="Complete Sale" onAction="#handleCheckout" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Clear Cart" onAction="#handleClearCart"/>
            </HBox>
        </VBox>
    </right>
</BorderPane>
